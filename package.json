{
  "name": "raising",
  "version": "0.1.0",
  "private": true,
  "description": "raising — pastoral care reporting platform",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:server": "pnpm --filter raising-server dev",
    "dev:client": "pnpm --filter raising-client dev",
    "build": "pnpm --filter raising-server build && pnpm --filter raising-client build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "bcrypt",
      "esbuild"
    ]
  }
}
